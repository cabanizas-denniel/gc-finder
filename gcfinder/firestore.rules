rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Admins can read/write their own documents.
    match /admin/{adminId} {
        allow read, write: if request.auth.uid == adminId;
    }
    
    // Students can read/write their own documents. Admins can read all student data.
    match /students/{studentId} {
        allow get: if request.auth != null; // Any authenticated user can get a student doc.
        allow list: if isAdmin(); // Only admins can list all students.
        allow create: if isAdmin(); // Only admins can create students.
        allow update, delete: if isAdmin() || request.auth.uid == studentId; // Admins or the student themselves.
    }

    // Officials/Faculty can read/write their own documents. Admins can manage all officials.
    match /officials/{officialId} {
        allow get: if request.auth != null; // Any authenticated user can get an official doc (for login).
        allow list: if isAdmin(); // Only admins can list all officials.
        allow create: if isAdmin(); // Only admins can create officials.
        allow update, delete: if isAdmin() || request.auth.uid == officialId; // Admins or the official themselves.
    }

    // Items can be created by authenticated users. Only admins can delete/update.
    match /items/{itemId} {
        allow read: if request.auth != null; // Any authenticated user can view items.
        allow create: if request.auth != null; // Any authenticated user can report an item.
        allow update, delete: if isAdmin(); // Only admins can manage items.
    }

    // Claims can be created by authenticated users. Only admins can update them.
    match /claims/{claimId} {
        allow read: if request.auth != null; // Any authenticated user can read claims.
        allow create: if request.auth.uid == request.resource.data.claimerId; // User can only create a claim for themselves.
        allow update: if isAdmin(); // Only admins can approve/reject claims.
        allow delete: if false; // Claims should probably not be deleted by clients.
    }

    // Participants of a conversation can read/write messages.
    match /conversations/{conversationId} {
        // Allow authenticated users to list conversations (filtered by app logic)
        allow list: if request.auth != null;
        // Allow get if document doesn't exist (for checking) or if user is participant
        allow get: if request.auth != null && 
                      (resource == null || isAdmin() || request.auth.uid in resource.data.participants);
        allow update: if request.auth != null && 
                         (isAdmin() || request.auth.uid in resource.data.participants);
        // Allow any authenticated user to create conversations
        allow create: if request.auth != null;
    }

    match /conversations/{conversationId}/messages/{messageId} {
        // Authenticated users who are participants can create messages
        allow create: if request.auth != null 
                       && request.auth.uid == request.resource.data.senderId
                       && (isAdmin() || request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants);
        // Participants can read messages (check if user is in conversation participants array)
        allow read: if isAdmin() || 
                       request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow update, delete: if false; // Don't allow message edits/deletes from client.
    }

    // Explicitly block direct client access to Lost Requests and Lost Items.
    // Access should go through secured backend (Flask) which enforces RBAC and data sanitization.
    match /lost_requests/{requestId} {
        allow read, write: if false;
    }
    match /lost_items/{itemId} {
        allow read, write: if false;
    }

    // Helper function to check for admin role (includes officials for messaging access)
    function isAdmin() {
      // Check for a custom claim OR existence in the 'admin' collection OR officials collection.
      // Officials (Disciplinary Office staff) need admin-level access for messaging.
      return request.auth.token.isAdmin == true 
             || exists(/databases/$(database)/documents/admin/$(request.auth.uid))
             || exists(/databases/$(database)/documents/officials/$(request.auth.uid));
    }
  }
}